      "groceryList[].item": "Ingredient name",
      "groceryList[].quantity": "Amount needed (e.g., '2 lbs', '1 bunch', '8 oz')",
      "groceryList[].forRecipes": "Array of recipe names this ingredient is used in",
      "notes": "Optional string for any notes about this week (substitutions made, items out of stock, etc.)"
    }
